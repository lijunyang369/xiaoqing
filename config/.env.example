# OpenClaw local secrets for this machine
# Copy to .env (or set as system/user env vars) and fill real values.
# Do NOT commit the real .env.

# Gateway auth for Control UI / local APIs
OPENCLAW_GATEWAY_TOKEN=replace-me

# Discord bots
DISCORD_BOT_TOKEN=replace-me
DISCORD_BOT_TOKEN_QINGLAN=replace-me

# Optional: if you later move other providers to env, add them here.
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# BRAVE_API_KEY=
